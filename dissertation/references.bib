@misc{IBN1113,
   abstract = {The evolution of both 5G and 6G networks is driving the advancement of fully autonomous network management, placing intent-based networking (IBN) at the center of this transformation. This paper introduces a novel framework targeting 5G and 6G IBN orchestration, which leverages a stateful, hierarchical multi-agent architecture to achieve full automation using both SLMs and LLMs. Both LLMs and LLMs have been evaluated in terms of translation accuracy using metrics like BLEU, METEOR, and ROUGE-L and computational complexity. Experimental results have shown that both models exhibit similar performance in terms of accuracy. However SLMs improve the overall IBN lifecycle completion speed by 20%.},
   author = {Wai Lwin and Brahim El Boudani and Tasos Dagiuklas and Saptarshi Ghosh},
   keywords = {Index Terms-IBN,LLM,Orchestration,SLM},
   title = {Performance Comparison of IBN orchestration using LLM and SLMs}
}

